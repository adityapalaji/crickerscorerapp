{
  "framework": "nextjs",
  "rewrites": [
    { "source": "/((?!api/|_next/|match/|favicon\\.png|opengraph\\.jpg).*)", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/match/:matchId",
      "headers": [
        {
          "key": "x-vercel-protection-bypass",
          "value": "rba_public"
        }
      ]
    }
  ]
}
