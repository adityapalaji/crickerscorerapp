# Vercel KV Configuration (Required in Production)
# Get these values from Vercel project settings -> Storage -> KV
KV_REST_API_URL=https://your-project-id.kv.vercel.sh
KV_REST_API_TOKEN=your-kv-token-here

# Optional: Public app origin for match sharing
# NEXT_PUBLIC_APP_ORIGIN=https://your-domain.com

# Optional: Admin key for API protection (must be verified server-side)
# ADMIN_KEY=your-secure-admin-key

# Environment (automatically set by Vercel)
NODE_ENV=production
